# Database Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/barber_db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3002

# Email Configuration (Gmail with App Password)
# To use Gmail, enable 2FA and generate an app-specific password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Create an App Password for "Mail" on "Windows Computer"
# 4. Use the 16-character password below
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password

# Alternative: If using a different email service (SendGrid, AWS SES, etc.)
# Update emailService.js accordingly

# Razorpay Configuration (Test Mode)
RAZORPAY_KEY_ID=rzp_test_RpvVPNs4PXPDQn
RAZORPAY_KEY_SECRET=your_key_secret_here

# Twilio Configuration (Optional - for SMS notifications)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Node Environment
NODE_ENV=development
