{
  "name": "barberflow",
  "version": "1.0.0",
  "description": "BarberFlow - Simple Barber Shop Management Desktop App",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "electron-dev": "electron .",
    "electron-build": "npm run build-frontend && electron-builder",
    "build-frontend": "cd ../frontend && npm run build && cd ../backend",
    "build": "npm run build-frontend && electron-builder --publish never",
    "build-win": "npm run build && electron-builder --win --publish never",
    "build-mac": "npm run build && electron-builder --mac --publish never",
    "build-linux": "npm run build && electron-builder --linux --publish never",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "migrate:mongo-to-pg": "node src/migrations/mongoToPg.js"
  },
  "keywords": [
    "barber",
    "booking",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^7.0.0",
    "nodemailer": "^7.0.11",
    "stripe": "^20.0.0",
    "twilio": "^4.23.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "nodemon": "^3.0.2",
    "prisma": "^5.8.0"
  },
  "build": {
    "appId": "com.barberflow.app",
    "productName": "BarberFlow",
    "files": [
      "public/**/*",
      "src/**/*",
      "node_modules/**/*",
      ".env.production"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "portable"
      ],
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BarberFlow"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office"
    }
  }
}
